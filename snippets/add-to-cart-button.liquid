{% doc %}
  This snippet is used to display the add to cart button.
  Intended for add-to-cart.liquid block.

  @param {string} can_add_to_cart - Whether the product can be added to the cart
  @param {string} add_to_cart_text - The text of the add to cart button
  @param {string} product - The product to add to the cart
  @param {boolean} [icon_only_on_mobile] - Whether the icon is only visible on mobile
  @param {string} class - The class of the button
  @param {string} [id] - The id of the button
{% enddoc %}

{%- liquid
  assign default_add_to_cart_text = 'actions.add_to_cart' | t
  assign product_variant_media = product.selected_or_first_available_variant.featured_media.preview_image | image_url: width: 100
  assign button_class = 'button ' | append: class
  assign show_inline_stock_status = false
  if enable_custom_button_styles
    assign button_class = button_class | append: ' add-to-cart-button--customizable'
  endif
  if show_stock_status and can_add_to_cart
    assign show_inline_stock_status = true
    assign button_class = button_class | append: ' add-to-cart-button--with-stock-status'
  endif
  if product.selected_or_first_available_variant.featured_media.preview_image == blank
    assign product_variant_media = product.featured_media.preview_image | image_url: width: 100
  endif
-%}

<add-to-cart-component
  ref="addToCartButtonContainer"
  data-product-variant-media="{{ product_variant_media }}"
>
  <button
    id="{{ id }}"
    type="submit"
    name="add"
    ref="addToCartButton"
    on:click="/handleClick"
    class="{{ button_class }}"
    {% unless can_add_to_cart %}
      disabled
    {% endunless %}
  >
    <span class="add-to-cart-text{% if show_inline_stock_status %} add-to-cart-text--with-status{% endif %}">
      <span class="add-to-cart-text__main">
        {% if can_add_to_cart %}
          <span class="svg-wrapper add-to-cart-icon">
            {{- 'icon-add-to-cart.svg' | inline_asset_content -}}
          </span>
        {% endif %}
        <span class="add-to-cart-text__content{% if icon_only_on_mobile %} is-visually-hidden-mobile{% endif %}">
          {{- add_to_cart_text | default: default_add_to_cart_text -}}
        </span>
      </span>
      {% if show_inline_stock_status %}
        <span class="add-to-cart-stock-status">
          <span class="add-to-cart-stock-status__dot"></span>
          <span>{{ stock_status_text }}</span>
        </span>
      {% endif %}
    </span>
    <span
      aria-hidden="true"
      class="add-to-cart-text--added"
    >
      <span class="svg-wrapper add-to-cart-icon--added">
        {{- 'icon-checkmark.svg' | inline_asset_content -}}
      </span>
      <span class="{% if icon_only_on_mobile %}is-visually-hidden-mobile{% endif %}">
        {{- 'actions.added' | t -}}
      </span>
    </span>
  </button>
</add-to-cart-component>

{% stylesheet %}
  .add-to-cart-text {
    display: flex;
    gap: var(--gap-2xs);
    align-items: center;
    justify-content: center;
    animation-duration: var(--animation-speed);
    animation-timing-function: var(--animation-easing);
    animation-fill-mode: forwards;
    transition: opacity var(--animation-speed) var(--animation-easing);
  }

  .add-to-cart-text__main {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--gap-2xs);
  }

  .add-to-cart-text--with-status {
    flex-direction: column;
    gap: 0;
  }

  .add-to-cart-button--with-stock-status {
    height: auto;
    min-height: var(--height-buy-buttons);
    padding-block: var(--padding-sm);
  }

  .add-to-cart-button--customizable {
    border-radius: var(--atc-border-radius);
    background: var(--atc-background);
    color: var(--atc-text-color);
    border-color: var(--atc-border-color);
    border-width: var(--atc-border-width);
    border-style: solid;
  }

  .add-to-cart-button--customizable .add-to-cart-text__content {
    font-size: var(--atc-label-size);
  }

  .add-to-cart-button--customizable:hover:not(:disabled),
  .add-to-cart-button--customizable:focus-visible:not(:disabled) {
    background: var(--atc-background-hover);
    color: var(--atc-text-color-hover);
    border-color: var(--atc-border-color-hover);
  }

  .add-to-cart-stock-status {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--gap-xs);
    margin-top: var(--stock-status-spacing-top, 4px);
    margin-bottom: var(--stock-status-spacing-bottom, 0);
    font-size: var(--stock-status-text-size, var(--font-size--sm));
    color: var(--stock-status-text-color, currentColor);
    line-height: 1.2;
  }

  .add-to-cart-stock-status__dot {
    width: var(--stock-status-dot-size, 10px);
    height: var(--stock-status-dot-size, 10px);
    min-width: var(--stock-status-dot-size, 10px);
    border-radius: 50%;
    background: var(--stock-status-dot-color, #2da54e);
    box-shadow: 0 0 0 0 color-mix(in srgb, var(--stock-status-dot-color, #2da54e) 45%, transparent);
    animation: stock-status-pulse var(--stock-status-pulse-speed, 1.8s) ease-out infinite;
  }

  @keyframes stock-status-pulse {
    0% {
      transform: scale(0.95);
      box-shadow: 0 0 0 0 color-mix(in srgb, var(--stock-status-dot-color, #2da54e) 45%, transparent);
    }
    70% {
      transform: scale(1);
      box-shadow: 0 0 0 9px color-mix(in srgb, var(--stock-status-dot-color, #2da54e) 0%, transparent);
    }
    100% {
      transform: scale(0.95);
      box-shadow: 0 0 0 0 color-mix(in srgb, var(--stock-status-dot-color, #2da54e) 0%, transparent);
    }
  }

  .atc-added .add-to-cart-text {
    animation-name: atc-slide-out;
  }

  .add-to-cart-text--added {
    position: absolute;
    inset: 0;
    animation-duration: var(--animation-speed);
    animation-timing-function: var(--animation-easing);
    animation-fill-mode: forwards;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: width var(--animation-speed) var(--animation-easing),
      opacity var(--animation-speed) var(--animation-easing);
  }

  .atc-added .add-to-cart-text--added {
    animation-name: atc-slide-in;
  }

  @keyframes atc-slide-in {
    from {
      opacity: 0;
      transform: translateY(0.5em);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes atc-slide-out {
    from {
      transform: translateY(0);
      opacity: 1;
    }

    to {
      transform: translateY(-1em);
      opacity: 0;
    }
  }
{% endstylesheet %}