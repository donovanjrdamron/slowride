{% liquid
  assign background_image = section.settings.background_image
  assign background_overlay_opacity = section.settings.background_overlay_opacity | times: 0.01
  assign section_height = section.settings.section_height
  assign section_max_width = section.settings.section_max_width
  assign card_max_width = section.settings.card_max_width
  assign card_min_height = section.settings.card_min_height
  assign card_radius = section.settings.card_radius
  assign card_blur = section.settings.card_blur
  assign glass_opacity = section.settings.glass_opacity | times: 0.01
  assign border_opacity = section.settings.border_opacity | times: 0.01
  assign shadow_opacity = section.settings.shadow_opacity | times: 0.01
  assign content_padding = section.settings.content_padding
  assign desktop_split = section.settings.desktop_split
  assign heading = section.settings.heading
  assign eyebrow = section.settings.eyebrow
  assign body = section.settings.body
  assign button_label = section.settings.button_label
  assign button_link = section.settings.button_link
  assign video = section.settings.video
  assign external_video_url = section.settings.external_video_url
  assign poster_image = section.settings.poster_image
%}

<section
  class="frosted-split frosted-split--{{ section.id }}"
  style="
    --frosted-section-height: {{ section_height }}svh;
    --frosted-section-max-width: {{ section_max_width }}px;
    --frosted-card-max-width: {{ card_max_width }}px;
    --frosted-card-min-height: {{ card_min_height }}px;
    --frosted-card-radius: {{ card_radius }}px;
    --frosted-card-blur: {{ card_blur }}px;
    --frosted-glass-opacity: {{ glass_opacity }};
    --frosted-border-opacity: {{ border_opacity }};
    --frosted-shadow-opacity: {{ shadow_opacity }};
    --frosted-content-padding: {{ content_padding }}px;
    --frosted-desktop-split: {{ desktop_split }}fr 1fr;
    --frosted-overlay-opacity: {{ background_overlay_opacity }};
    --frosted-padding-top: {{ section.settings.padding_top }}px;
    --frosted-padding-bottom: {{ section.settings.padding_bottom }}px;
    --frosted-text-color: {{ section.settings.text_color }};
    --frosted-button-bg: {{ section.settings.button_background_color }};
    --frosted-button-text: {{ section.settings.button_text_color }};
    --frosted-button-border: {{ section.settings.button_border_color }};
  "
>
  <div class="frosted-split__media-layer">
    {% if background_image != blank %}
      {{ background_image | image_url: width: 3200 | image_tag: class: 'frosted-split__bg-image', loading: 'lazy', widths: '750, 1100, 1500, 2200, 3000', sizes: '100vw', alt: background_image.alt }}
    {% else %}
      <div class="frosted-split__bg-placeholder"></div>
    {% endif %}
    <div class="frosted-split__overlay"></div>
  </div>

  <div class="frosted-split__inner">
    <div class="frosted-split__card">
      <div class="frosted-split__left">
        {% if eyebrow != blank %}
          <p class="frosted-split__eyebrow">{{ eyebrow | escape }}</p>
        {% endif %}

        {% if heading != blank %}
          <h2 class="frosted-split__heading">{{ heading | escape }}</h2>
        {% endif %}

        {% if body != blank %}
          <div class="frosted-split__body">{{ body }}</div>
        {% endif %}

        {% if button_label != blank %}
          <a
            {% if button_link == blank %}
              role="link" aria-disabled="true"
            {% else %}
              href="{{ button_link }}"
            {% endif %}
            class="frosted-split__button"
          >
            {{ button_label | escape }}
          </a>
        {% endif %}
      </div>

      <div class="frosted-split__right">
        {% if video != blank %}
          {{
            video
            | video_tag:
              class: 'frosted-split__video js-frosted-video',
              autoplay: true,
              loop: true,
              muted: true,
              controls: false,
              playsinline: true,
              preload: 'metadata',
              image_size: '1500x'
          }}
        {% elsif external_video_url != blank %}
          <video
            class="frosted-split__video js-frosted-video"
            autoplay
            muted
            loop
            playsinline
            preload="metadata"
            {% if poster_image != blank %}
              poster="{{ poster_image | image_url: width: 1500 }}"
            {% endif %}
          >
            <source src="{{ external_video_url | escape }}" type="video/mp4">
          </video>
        {% elsif poster_image != blank %}
          {{ poster_image | image_url: width: 1500 | image_tag: class: 'frosted-split__video-fallback', loading: 'lazy', widths: '750, 1100, 1500', sizes: '(min-width: 750px) 40vw, 100vw', alt: poster_image.alt }}
        {% else %}
          <div class="frosted-split__video-fallback frosted-split__video-fallback--empty" aria-hidden="true"></div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<script>
  (() => {
    const sectionRoot = document.querySelector('.frosted-split--{{ section.id }}');
    if (!sectionRoot) return;

    if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      sectionRoot.querySelectorAll('.js-frosted-video').forEach((video) => {
        video.removeAttribute('autoplay');
        video.pause();
      });
    }
  })();
</script>

{% stylesheet %}
  .frosted-split {
    position: relative;
    isolation: isolate;
    min-height: var(--frosted-section-height);
    padding-top: var(--frosted-padding-top);
    padding-bottom: var(--frosted-padding-bottom);
    overflow: hidden;
  }

  .frosted-split__media-layer {
    position: absolute;
    inset: 0;
    z-index: -1;
  }

  .frosted-split__bg-image,
  .frosted-split__bg-placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .frosted-split__bg-placeholder {
    background: linear-gradient(135deg, #3a4058, #1f2436 60%, #3f5668);
  }

  .frosted-split__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, var(--frosted-overlay-opacity));
  }

  .frosted-split__inner {
    max-width: var(--frosted-section-max-width);
    margin: 0 auto;
    padding-inline: clamp(16px, 3vw, 36px);
    min-height: inherit;
    display: grid;
    place-items: center;
  }

  .frosted-split__card {
    width: min(100%, var(--frosted-card-max-width));
    min-height: var(--frosted-card-min-height);
    display: grid;
    grid-template-columns: 1fr;
    border-radius: var(--frosted-card-radius);
    overflow: hidden;
    backdrop-filter: blur(var(--frosted-card-blur));
    -webkit-backdrop-filter: blur(var(--frosted-card-blur));
    background: rgba(255, 255, 255, var(--frosted-glass-opacity));
    border: 1px solid rgba(255, 255, 255, var(--frosted-border-opacity));
    box-shadow: 0 12px 34px rgba(0, 0, 0, var(--frosted-shadow-opacity));
  }

  .frosted-split__left {
    padding: var(--frosted-content-padding);
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 14px;
    color: var(--frosted-text-color);
  }

  .frosted-split__eyebrow {
    margin: 0;
    font-size: 0.82rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.85;
  }

  .frosted-split__heading {
    margin: 0;
    font-size: clamp(1.8rem, 4vw, 3.2rem);
    line-height: 1.08;
    color: var(--frosted-text-color);
  }

  .frosted-split__body {
    margin: 0;
    max-width: 42ch;
    color: var(--frosted-text-color);
  }

  .frosted-split__body p {
    margin: 0;
  }

  .frosted-split__button {
    margin-top: 12px;
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0.68rem 1.6rem;
    border-radius: 999px;
    text-decoration: none;
    border: 1px solid var(--frosted-button-border);
    color: var(--frosted-button-text);
    background: var(--frosted-button-bg);
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .frosted-split__button:hover {
    opacity: 0.92;
    transform: translateY(-1px);
  }

  .frosted-split__button[aria-disabled='true'] {
    opacity: 0.65;
    pointer-events: none;
  }

  .frosted-split__right {
    min-height: min(62vw, 380px);
    background: rgba(10, 10, 10, 0.08);
  }

  .frosted-split__video,
  .frosted-split__video-fallback {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .frosted-split__video-fallback--empty {
    background: linear-gradient(140deg, rgba(40, 40, 40, 0.3), rgba(15, 15, 15, 0.4));
  }

  @media screen and (min-width: 750px) {
    .frosted-split__card {
      grid-template-columns: var(--frosted-desktop-split);
    }

    .frosted-split__right {
      min-height: 100%;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Frosted glass split",
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
