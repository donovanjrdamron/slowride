<style>
  @import url('https://fonts.googleapis.com/css2?family=Anton&display=swap');

  .vintage-racing-section {
    position: relative;
    background: #FFFFFF;
    padding: 80px 0;
    overflow: hidden;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  }

  /* ── Swooping stripe system (Toyota Trophy Truck livery) ── */

  .vintage-racing-section .stripe-container {
    position: absolute;
    inset: 0;
    overflow: hidden;
    z-index: 0;
    pointer-events: none;
  }

  .vintage-racing-section .stripe {
    position: absolute;
    inset: 0;
  }

  .vintage-racing-section .stripe--yellow {
    background: #F2A900;
    clip-path: polygon(0% 68%, 50% 50%, 100% 42%, 100% 62%, 50% 72%, 0% 92%);
  }

  .vintage-racing-section .stripe--orange {
    background: #D4541A;
    clip-path: polygon(0% 48%, 50% 32%, 100% 24%, 100% 40%, 50% 50%, 0% 66%);
  }

  .vintage-racing-section .stripe--red {
    background: #B01A0E;
    clip-path: polygon(0% 30%, 50% 16%, 100% 8%, 100% 22%, 50% 30%, 0% 46%);
  }

  /* ── Content layer ── */

  .vintage-racing-section .vrg-inner {
    position: relative;
    z-index: 2;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* ── Section header ── */

  .vintage-racing-section .vrg-header {
    text-align: center;
    margin-bottom: 48px;
  }

  .vintage-racing-section .vrg-heading {
    font-family: 'Anton', Impact, sans-serif;
    font-size: 52px;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #1a1008;
    margin: 0 0 10px;
    line-height: 1.1;
  }

  .vintage-racing-section .vrg-subheading {
    font-size: 14px;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #D4541A;
    margin: 0 0 20px;
  }


  /* ── Product grid ── */

  .vintage-racing-section .vrg-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  /* ── Frosted glass product cards ── */

  .vintage-racing-section .product-card {
    position: relative;
    background: rgba(255, 255, 255, 0.45);
    backdrop-filter: blur(18px) saturate(160%);
    -webkit-backdrop-filter: blur(18px) saturate(160%);
    border: 1px solid rgba(255, 255, 255, 0.75);
    border-radius: 16px;
    box-shadow:
      0 8px 32px rgba(0, 0, 0, 0.10),
      inset 0 1px 0 rgba(255, 255, 255, 0.85);
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    padding: 16px;
  }

  .vintage-racing-section .product-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 50%;
    background: linear-gradient(
      to bottom,
      rgba(255, 255, 255, 0.35) 0%,
      rgba(255, 255, 255, 0.00) 100%
    );
    border-radius: 16px 16px 0 0;
    pointer-events: none;
    z-index: 3;
  }

  .vintage-racing-section .card--odd {
    transform: translateY(-12px);
  }

  .vintage-racing-section .card--even {
    transform: translateY(12px);
  }

  .vintage-racing-section .card--odd:hover {
    transform: translateY(-18px);
    box-shadow:
      0 14px 40px rgba(0, 0, 0, 0.16),
      inset 0 1px 0 rgba(255, 255, 255, 0.85);
  }

  .vintage-racing-section .card--even:hover {
    transform: translateY(6px);
    box-shadow:
      0 14px 40px rgba(0, 0, 0, 0.16),
      inset 0 1px 0 rgba(255, 255, 255, 0.85);
  }

  /* ── Race number ── */

  .vintage-racing-section .vrg-race-number {
    position: absolute;
    top: 8px;
    right: 16px;
    font-family: 'Anton', Impact, sans-serif;
    font-size: 96px;
    font-weight: 400;
    line-height: 1;
    color: rgba(176, 26, 14, 0.10);
    z-index: 0;
    pointer-events: none;
    user-select: none;
  }

  /* ── Product image ── */

  .vintage-racing-section .vrg-card-image {
    position: relative;
    z-index: 1;
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: 10px;
  }

  .vintage-racing-section .vrg-card-image img,
  .vintage-racing-section .vrg-card-image svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ── Card content ── */

  .vintage-racing-section .vrg-card-content {
    position: relative;
    z-index: 1;
    padding-top: 12px;
  }

  .vintage-racing-section .vrg-product-title {
    font-family: 'Anton', Impact, sans-serif;
    font-size: 16px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #1a1008;
    margin: 0 0 4px;
    line-height: 1.3;
  }

  .vintage-racing-section .vrg-product-price {
    font-size: 14px;
    font-weight: 600;
    color: #D4541A;
    margin: 0 0 14px;
  }

  .vintage-racing-section .vrg-btn {
    display: inline-block;
    padding: 10px 24px;
    border: 2px solid #B01A0E;
    border-radius: 999px;
    background: transparent;
    color: #B01A0E;
    font-family: 'Anton', Impact, sans-serif;
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background 0.25s ease, color 0.25s ease;
    cursor: pointer;
  }

  .vintage-racing-section .vrg-btn:hover {
    background: #B01A0E;
    color: #FFFFFF;
  }

  /* ── Empty state ── */

  .vintage-racing-section .vrg-empty {
    text-align: center;
    color: #999;
    padding: 40px 0;
    grid-column: 1 / -1;
  }

  /* ── Mobile ── */

  @media (max-width: 768px) {
    .vintage-racing-section {
      padding: 48px 0;
    }

    .vintage-racing-section .vrg-heading {
      font-size: 32px;
    }

    .vintage-racing-section .vrg-grid {
      grid-template-columns: 1fr;
    }

    .vintage-racing-section .card--odd,
    .vintage-racing-section .card--even {
      transform: translateY(0);
    }

    .vintage-racing-section .card--odd:hover,
    .vintage-racing-section .card--even:hover {
      transform: translateY(-6px);
    }
  }
</style>

<section class="vintage-racing-section" id="vintage-racing-grid-{{ section.id }}">
  <div class="stripe-container">
    <div class="stripe stripe--yellow"></div>
    <div class="stripe stripe--orange"></div>
    <div class="stripe stripe--red"></div>
  </div>

  <div class="vrg-inner">
    <div class="vrg-header">
      <h2 class="vrg-heading">{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="vrg-subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    {%- assign racing_collection = collections[section.settings.collection] -%}
    {%- if racing_collection != blank and racing_collection.products.size > 0 -%}
      <div class="vrg-grid">
        {%- for product in racing_collection.products limit: 4 -%}
          {%- assign card_mod = forloop.index | modulo: 2 -%}
          <div class="product-card {% if card_mod == 1 %}card--odd{% else %}card--even{% endif %}">
            {%- if section.settings.show_race_numbers -%}
              <span class="vrg-race-number">{{ forloop.index | prepend: '0' }}</span>
            {%- endif -%}

            <div class="vrg-card-image">
              {%- if product.featured_image -%}
                {{
                  product.featured_image
                  | image_url: width: 600
                  | image_tag:
                    loading: 'lazy',
                    alt: product.title
                }}
              {%- else -%}
                {{ 'product-1' | placeholder_svg_tag }}
              {%- endif -%}
            </div>

            <div class="vrg-card-content">
              <h3 class="vrg-product-title">{{ product.title }}</h3>
              <p class="vrg-product-price">{{ product.price | money }}</p>
              <a href="{{ product.url }}" class="vrg-btn">
                {{ section.settings.button_label }}
              </a>
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- else -%}
      <p class="vrg-empty">Select a collection in the section settings.</p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Vintage Racing Grid",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Iron Man Collection"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "1980s Vintage Racing Series · Limited Run"
    },
    {
      "type": "checkbox",
      "id": "show_race_numbers",
      "label": "Show race numbers",
      "default": true
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop Now"
    }
  ],
  "presets": [
    {
      "name": "Vintage Racing Grid"
    }
  ]
}
{% endschema %}
