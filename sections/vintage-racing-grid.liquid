<style>
  @import url('https://fonts.googleapis.com/css2?family=Anton&display=swap');

  #vintage-racing-grid-{{ section.id }} {
    --vrg-bg: #1a1008;
    --vrg-accent: #C4541A;
    --vrg-red: #8B1A0E;
    --vrg-tan: #D4925A;
    --vrg-text: #F0E6D3;
    --vrg-card-bg: #231508;
    --vrg-font: 'Anton', Impact, sans-serif;

    position: relative;
    background: var(--vrg-bg);
    color: var(--vrg-text);
    padding: 80px 0;
    overflow: hidden;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  }

  /* Checkered flag border along top edge */
  #vintage-racing-grid-{{ section.id }}::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 12px;
    background: repeating-linear-gradient(
      90deg,
      var(--vrg-accent) 0px,
      var(--vrg-accent) 12px,
      var(--vrg-bg) 12px,
      var(--vrg-bg) 24px
    );
    -webkit-mask-image: repeating-linear-gradient(
      180deg,
      #000 0px,
      #000 12px,
      transparent 12px,
      transparent 24px
    ),
    repeating-linear-gradient(
      90deg,
      #000 0px,
      #000 12px,
      transparent 12px,
      transparent 24px
    );
    -webkit-mask-composite: source-in;
    mask-image: repeating-conic-gradient(#000 0% 25%, transparent 0% 50%);
    mask-size: 24px 24px;
    z-index: 2;
  }

  #vintage-racing-grid-{{ section.id }} .vrg-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    position: relative;
    z-index: 1;
  }

  /* Header */
  #vintage-racing-grid-{{ section.id }} .vrg-header {
    text-align: center;
    margin-bottom: 48px;
  }

  #vintage-racing-grid-{{ section.id }} .vrg-heading {
    font-family: var(--vrg-font);
    font-size: clamp(36px, 6vw, 64px);
    font-weight: 400;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--vrg-text);
    margin: 0 0 8px;
    line-height: 1.1;
  }

  #vintage-racing-grid-{{ section.id }} .vrg-subheading {
    font-size: 14px;
    font-weight: 300;
    letter-spacing: 0.08em;
    color: var(--vrg-tan);
    margin: 0 0 24px;
    text-transform: uppercase;
  }

  /* Double pinstripe rule */
  #vintage-racing-grid-{{ section.id }} .vrg-pinstripe {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  #vintage-racing-grid-{{ section.id }} .vrg-pinstripe-thin {
    width: 120px;
    height: 1px;
    background: var(--vrg-accent);
  }

  #vintage-racing-grid-{{ section.id }} .vrg-pinstripe-thick {
    width: 120px;
    height: 3px;
    background: var(--vrg-accent);
  }

  /* Diagonal speed stripes */
  #vintage-racing-grid-{{ section.id }} .vrg-grid-wrapper {
    position: relative;
  }

  #vintage-racing-grid-{{ section.id }} .vrg-speed-stripe {
    position: absolute;
    top: -40px;
    bottom: -40px;
    width: 180px;
    background: var(--vrg-accent);
    opacity: 0.06;
    transform: skewX(-25deg);
    pointer-events: none;
    z-index: 0;
  }

  #vintage-racing-grid-{{ section.id }} .vrg-speed-stripe--1 {
    left: 8%;
  }

  #vintage-racing-grid-{{ section.id }} .vrg-speed-stripe--2 {
    right: 12%;
    width: 100px;
  }

  /* Product grid */
  #vintage-racing-grid-{{ section.id }} .vrg-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    position: relative;
    z-index: 1;
  }

  #vintage-racing-grid-{{ section.id }} .vrg-card:nth-child(odd) {
    margin-top: 0;
  }

  #vintage-racing-grid-{{ section.id }} .vrg-card:nth-child(even) {
    margin-top: 24px;
  }

  /* Product card */
  #vintage-racing-grid-{{ section.id }} .vrg-card {
    position: relative;
    background: var(--vrg-card-bg);
    border: 1px solid rgba(196, 84, 26, 0.3);
    box-shadow: 0 4px 24px rgba(196, 84, 26, 0.12);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    overflow: hidden;
  }

  #vintage-racing-grid-{{ section.id }} .vrg-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 32px rgba(196, 84, 26, 0.25);
  }

  /* Race number */
  #vintage-racing-grid-{{ section.id }} .vrg-race-number {
    position: absolute;
    top: 8px;
    right: 12px;
    font-family: var(--vrg-font);
    font-size: 80px;
    font-weight: 400;
    line-height: 1;
    color: var(--vrg-accent);
    opacity: 0.12;
    z-index: 1;
    pointer-events: none;
    user-select: none;
  }

  /* Product image */
  #vintage-racing-grid-{{ section.id }} .vrg-card-image {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
  }

  #vintage-racing-grid-{{ section.id }} .vrg-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Card content */
  #vintage-racing-grid-{{ section.id }} .vrg-card-content {
    padding: 20px;
  }

  #vintage-racing-grid-{{ section.id }} .vrg-product-title {
    font-family: var(--vrg-font);
    font-size: 18px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--vrg-text);
    margin: 0 0 6px;
    line-height: 1.2;
  }

  #vintage-racing-grid-{{ section.id }} .vrg-product-price {
    font-size: 15px;
    color: var(--vrg-tan);
    margin: 0 0 16px;
    font-weight: 400;
  }

  #vintage-racing-grid-{{ section.id }} .vrg-btn {
    display: inline-block;
    padding: 10px 28px;
    border: 1.5px solid var(--vrg-accent);
    border-radius: 999px;
    background: transparent;
    color: var(--vrg-text);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background 0.25s ease, color 0.25s ease;
    cursor: pointer;
  }

  #vintage-racing-grid-{{ section.id }} .vrg-btn:hover {
    background: var(--vrg-accent);
    color: #fff;
  }

  /* Empty state */
  #vintage-racing-grid-{{ section.id }} .vrg-empty {
    text-align: center;
    opacity: 0.5;
    padding: 40px 0;
    grid-column: 1 / -1;
  }

  /* Mobile */
  @media (max-width: 768px) {
    #vintage-racing-grid-{{ section.id }} {
      padding: 48px 0;
    }

    #vintage-racing-grid-{{ section.id }} .vrg-grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    #vintage-racing-grid-{{ section.id }} .vrg-card:nth-child(even) {
      margin-top: 0;
    }

    #vintage-racing-grid-{{ section.id }} .vrg-heading {
      font-size: 32px;
    }

    #vintage-racing-grid-{{ section.id }} .vrg-speed-stripe {
      width: 100px;
    }

    #vintage-racing-grid-{{ section.id }} .vrg-speed-stripe--2 {
      width: 60px;
    }
  }
</style>

<div id="vintage-racing-grid-{{ section.id }}">
  <div class="vrg-inner">
    <div class="vrg-header">
      <h2 class="vrg-heading">{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="vrg-subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
      <div class="vrg-pinstripe">
        <div class="vrg-pinstripe-thin"></div>
        <div class="vrg-pinstripe-thick"></div>
      </div>
    </div>

    {%- if section.settings.collection != blank -%}
      <div class="vrg-grid-wrapper">
        <div class="vrg-speed-stripe vrg-speed-stripe--1"></div>
        <div class="vrg-speed-stripe vrg-speed-stripe--2"></div>

        <div class="vrg-grid">
          {%- for product in section.settings.collection.products limit: 4 -%}
            <div class="vrg-card">
              {%- if section.settings.show_race_numbers -%}
                <span class="vrg-race-number">{{ forloop.index | prepend: '0' }}</span>
              {%- endif -%}

              <div class="vrg-card-image">
                {%- if product.featured_image -%}
                  {{
                    product.featured_image
                    | image_url: width: 600
                    | image_tag:
                      loading: 'lazy',
                      alt: product.title,
                      class: 'vrg-img'
                  }}
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'vrg-img' }}
                {%- endif -%}
              </div>

              <div class="vrg-card-content">
                <h3 class="vrg-product-title">{{ product.title }}</h3>
                <p class="vrg-product-price">{{ product.price | money }}</p>
                <a href="{{ product.url }}" class="vrg-btn">
                  {{ section.settings.button_label }}
                </a>
              </div>
            </div>
          {%- endfor -%}
        </div>
      </div>
    {%- else -%}
      <p class="vrg-empty">Select a collection in the section settings.</p>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Vintage Racing Grid",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Collection"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "1980s Vintage Racing Series · Limited Run"
    },
    {
      "type": "checkbox",
      "id": "show_race_numbers",
      "label": "Show race numbers",
      "default": true
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop Now"
    }
  ],
  "presets": [
    {
      "name": "Vintage Racing Grid"
    }
  ]
}
{% endschema %}
