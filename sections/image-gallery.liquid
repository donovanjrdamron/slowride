<div class="sr-gallery-wrapper">

  <div class="sr-gallery-header" style="text-align: {{ section.settings.heading_align }}; margin-bottom: {{ section.settings.heading_gap }}px; padding: 0 24px;">
    <h2 class="sr-gallery-heading" style="font-size: {{ section.settings.heading_size }}px; color: {{ section.settings.heading_color }};">
      {{ section.settings.heading }}
    </h2>
  </div>

  <div class="sr-gallery-track" id="sr-track-{{ section.id }}">
    {% for i in (1..15) %}
      {% assign image_key = 'image_' | append: i %}
      {% assign image = section.settings[image_key] %}
      {% if image != blank %}
        <div class="sr-gallery-card">
          <img src="{{ image | image_url: width: 600 }}" alt="Gallery image {{ i }}" loading="lazy"/>
        </div>
      {% endif %}
    {% endfor %}
  </div>

  <div class="sr-gallery-dots" id="sr-dots-{{ section.id }}"></div>

</div>

{% style %}
.sr-gallery-wrapper {
  padding: {{ section.settings.section_padding_top }}px 0 {{ section.settings.section_padding_bottom }}px;
  overflow: hidden;
  background: {{ section.settings.background_color }};
}

.sr-gallery-heading {
  font-weight: 700;
  letter-spacing: 0.02em;
  line-height: 1.1;
  margin: 0;
}

.sr-gallery-track {
  display: flex;
  gap: {{ section.settings.card_gap }}px;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
  padding: 0 24px 4px;
  cursor: grab;
  user-select: none;
}

.sr-gallery-track:active { cursor: grabbing; }
.sr-gallery-track::-webkit-scrollbar { display: none; }

.sr-gallery-card {
  flex: 0 0 calc({{ section.settings.cards_per_row | times: 1.0 | divided_by: 100 | times: 100 }}% - {{ section.settings.card_gap }}px);
  scroll-snap-align: start;
  aspect-ratio: 1 / 1;
  border-radius: {{ section.settings.card_radius }}px;
  overflow: hidden;
  min-width: 160px;
  transition: transform 0.2s ease;
}

.sr-gallery-card:hover { transform: translateY(-3px); }

.sr-gallery-card img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.sr-gallery-dots {
  display: flex;
  justify-content: center;
  gap: 7px;
  margin-top: 20px;
}

.sr-gallery-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: #c0bab2;
  border: none;
  cursor: pointer;
  transition: background 0.2s, transform 0.2s;
  padding: 0;
}

.sr-gallery-dot.active {
  background: {{ section.settings.dot_color }};
  transform: scale(1.4);
}

@media (max-width: 600px) {
  .sr-gallery-card { flex: 0 0 78%; }
}
{% endstyle %}

<script>
document.querySelectorAll('.sr-gallery-track').forEach(track => {
  const cards = track.querySelectorAll('.sr-gallery-card');
  const dotsContainer = track.nextElementSibling;
  if (!cards.length || !dotsContainer) return;

  const perPage = window.innerWidth <= 600 ? 1 : 3;
  const totalDots = Math.ceil(cards.length / perPage);

  for (let i = 0; i < totalDots; i++) {
    const d = document.createElement('button');
    d.className = 'sr-gallery-dot' + (i === 0 ? ' active' : '');
    d.addEventListener('click', () => {
      track.scrollTo({ left: i * perPage * (cards[0].offsetWidth + 14), behavior: 'smooth' });
    });
    dotsContainer.appendChild(d);
  }

  track.addEventListener('scroll', () => {
    const page = Math.round(track.scrollLeft / (perPage * (cards[0].offsetWidth + 14)));
    dotsContainer.querySelectorAll('.sr-gallery-dot').forEach((d, i) => {
      d.classList.toggle('active', i === page);
    });
  });

  let isDown = false, startX, scrollStart;
  track.addEventListener('mousedown', e => { isDown = true; startX = e.pageX; scrollStart = track.scrollLeft; });
  track.addEventListener('mouseleave', () => isDown = false);
  track.addEventListener('mouseup', () => isDown = false);
  track.addEventListener('mousemove', e => {
    if (!isDown) return;
    e.preventDefault();
    track.scrollLeft = scrollStart - (e.pageX - startX);
  });
});
</script>

{% schema %}
{
  "name": "Image Gallery",
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading Text",
      "default": "Enjoy Getting There."
    },
    {
      "type": "select",
      "id": "heading_align",
      "label": "Heading Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#1c1a17"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading Size",
      "min": 20,
      "max": 80,
      "step": 2,
      "default": 48
    },
    {
      "type": "range",
      "id": "heading_gap",
      "label": "Space Below Heading",
      "min": 8,
      "max": 60,
      "step": 4,
      "default": 24
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "card_gap",
      "label": "Gap Between Cards",
      "min": 4,
      "max": 32,
      "step": 2,
      "default": 14
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Card Border Radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "default": 6
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 40
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 40
    },
    {
      "type": "color",
      "id": "dot_color",
      "label": "Active Dot Color",
      "default": "#1c1a17"
    },
    {
      "type": "header",
      "content": "Images"
    },
    { "type": "image_picker", "id": "image_1",  "label": "Image 1"  },
    { "type": "image_picker", "id": "image_2",  "label": "Image 2"  },
    { "type": "image_picker", "id": "image_3",  "label": "Image 3"  },
    { "type": "image_picker", "id": "image_4",  "label": "Image 4"  },
    { "type": "image_picker", "id": "image_5",  "label": "Image 5"  },
    { "type": "image_picker", "id": "image_6",  "label": "Image 6"  },
    { "type": "image_picker", "id": "image_7",  "label": "Image 7"  },
    { "type": "image_picker", "id": "image_8",  "label": "Image 8"  },
    { "type": "image_picker", "id": "image_9",  "label": "Image 9"  },
    { "type": "image_picker", "id": "image_10", "label": "Image 10" },
    { "type": "image_picker", "id": "image_11", "label": "Image 11" },
    { "type": "image_picker", "id": "image_12", "label": "Image 12" },
    { "type": "image_picker", "id": "image_13", "label": "Image 13" },
    { "type": "image_picker", "id": "image_14", "label": "Image 14" },
    { "type": "image_picker", "id": "image_15", "label": "Image 15" }
  ],
  "presets": [
    {
      "name": "Image Gallery"
    }
  ]
}
{% endschema %}
