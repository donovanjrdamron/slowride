{%- assign ov_r = section.settings.overlay_color | color_extract: 'red' -%}
{%- assign ov_g = section.settings.overlay_color | color_extract: 'green' -%}
{%- assign ov_b = section.settings.overlay_color | color_extract: 'blue' -%}
{%- assign ov_a = section.settings.overlay_opacity | times: 0.01 -%}

{%- assign vc_r = section.settings.video_card_bg_color | color_extract: 'red' -%}
{%- assign vc_g = section.settings.video_card_bg_color | color_extract: 'green' -%}
{%- assign vc_b = section.settings.video_card_bg_color | color_extract: 'blue' -%}
{%- assign vc_a = section.settings.video_card_bg_opacity | times: 0.01 -%}

{%- assign pb_r = section.settings.play_button_color | color_extract: 'red' -%}
{%- assign pb_g = section.settings.play_button_color | color_extract: 'green' -%}
{%- assign pb_b = section.settings.play_button_color | color_extract: 'blue' -%}

{%- assign video = section.settings.video -%}
{%- assign thumbnail = section.settings.video_thumbnail -%}

{%- if thumbnail != blank -%}
  {%- assign poster_url = thumbnail | image_url: width: 1200 -%}
{%- elsif video.preview_image -%}
  {%- assign poster_url = video.preview_image | image_url: width: 1200 -%}
{%- else -%}
  {%- assign poster_url = '' -%}
{%- endif -%}

<style>
  @import url('https://fonts.googleapis.com/css2?family=Anton&display=swap');

  #vintage-racing-about-{{ section.id }} {
    --vra-overlay: rgba({{ ov_r }}, {{ ov_g }}, {{ ov_b }}, {{ ov_a }});
    --vra-overline-color: {{ section.settings.overline_color }};
    --vra-heading-color: {{ section.settings.heading_color }};
    --vra-video-card-bg: rgba({{ vc_r }}, {{ vc_g }}, {{ vc_b }}, {{ vc_a }});
    --vra-video-title-color: {{ section.settings.video_title_color }};
    --vra-video-subtitle-color: {{ section.settings.video_subtitle_color }};
    --vra-play-bg: rgba({{ pb_r }}, {{ pb_g }}, {{ pb_b }}, 0.85);
    --vra-stripe-1: {{ section.settings.stripe_color_1 }};
    --vra-stripe-2: {{ section.settings.stripe_color_2 }};
    --vra-stripe-3: {{ section.settings.stripe_color_3 }};
  }

  .vintage-racing-about {
    position: relative;
    background: #1a1008;
    padding: 80px 0;
    overflow: hidden;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  }

  /* ── Background image layer ── */

  .vintage-racing-about .vra-bg-image {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .vintage-racing-about .vra-bg-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .vintage-racing-about .vra-bg-overlay {
    position: absolute;
    inset: 0;
    background: var(--vra-overlay);
    z-index: 1;
  }

  /* ── Mirrored stripe system ── */

  .vintage-racing-about .stripe-container {
    position: absolute;
    inset: 0;
    overflow: hidden;
    z-index: 2;
    pointer-events: none;
    transform: scaleX(-1);
  }

  .vintage-racing-about .stripe-container .stripe {
    position: absolute;
    left: 0;
    right: 0;
    height: 7%;
    bottom: 0;
  }

  .vintage-racing-about .stripe-container .stripe--1 {
    background: var(--vra-stripe-1);
    clip-path: polygon(0% 8%, 100% 22%, 100% 50%, 0% 38%);
  }

  .vintage-racing-about .stripe-container .stripe--2 {
    background: var(--vra-stripe-2);
    clip-path: polygon(0% 44%, 100% 54%, 100% 78%, 0% 68%);
  }

  .vintage-racing-about .stripe-container .stripe--3 {
    background: var(--vra-stripe-3);
    clip-path: polygon(0% 74%, 100% 82%, 100% 100%, 0% 96%);
  }

  /* ── Content layer ── */

  .vintage-racing-about .vra-inner {
    position: relative;
    z-index: 3;
    max-width: 900px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* ── Section header ── */

  .vintage-racing-about .vra-header {
    text-align: center;
    margin-bottom: 48px;
  }

  .vintage-racing-about .vra-overline {
    font-family: 'Anton', Impact, sans-serif;
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--vra-overline-color);
    margin: 0 0 10px;
  }

  .vintage-racing-about .vra-heading {
    font-family: 'Anton', Impact, sans-serif;
    font-size: clamp(40px, 5vw, 64px);
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--vra-heading-color);
    margin: 0;
    line-height: 1.1;
  }

  /* ── Video card ── */

  .vintage-racing-about .vra-video-card {
    position: relative;
    background: var(--vra-video-card-bg);
    backdrop-filter: blur(18px) saturate(160%);
    -webkit-backdrop-filter: blur(18px) saturate(160%);
    border: 1px solid rgba(255, 255, 255, 0.75);
    border-radius: 20px;
    box-shadow:
      0 8px 32px rgba(0, 0, 0, 0.10),
      inset 0 1px 0 rgba(255, 255, 255, 0.85);
    overflow: hidden;
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }

  .vintage-racing-about .vra-video-card.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .vintage-racing-about .vra-video-wrap {
    position: relative;
    width: 100%;
    line-height: 0;
  }

  .vintage-racing-about .vra-video-wrap video,
  .vintage-racing-about .vra-video-wrap .vra-thumb-img {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    display: block;
  }

  /* ── Play button overlay ── */

  .vintage-racing-about .vra-play-btn {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 64px;
    height: 64px;
    background: var(--vra-play-bg);
    backdrop-filter: blur(8px);
    border: 2px solid rgba(255, 255, 255, 0.60);
    border-radius: 50%;
    cursor: pointer;
    z-index: 5;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.25s ease, transform 0.25s ease;
  }

  .vintage-racing-about .vra-play-btn.is-hidden {
    opacity: 0;
    pointer-events: none;
    transform: translate(-50%, -50%) scale(0.85);
  }

  .vintage-racing-about .vra-play-btn::after {
    content: '';
    display: block;
    width: 0;
    height: 0;
    border-style: solid;
    border-width: 10px 0 10px 18px;
    border-color: transparent transparent transparent #FFFFFF;
    margin-left: 3px;
  }

  /* ── Caption bar ── */

  .vintage-racing-about .vra-caption {
    padding: 20px 24px;
    background: rgba(255, 255, 255, 0.30);
    border-top: 1px solid rgba(255, 255, 255, 0.50);
    display: flex;
    align-items: flex-start;
    gap: 12px;
  }

  .vintage-racing-about .vra-flag-icon {
    flex-shrink: 0;
    width: 16px;
    height: 16px;
    background-image: repeating-conic-gradient(#000 0% 25%, #fff 0% 50%);
    background-size: 6px 6px;
    border-radius: 2px;
    margin-top: 2px;
  }

  .vintage-racing-about .vra-caption-text {
    display: flex;
    flex-direction: column;
  }

  .vintage-racing-about .vra-video-title {
    font-family: 'Anton', Impact, sans-serif;
    font-size: 14px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--vra-video-title-color);
    margin: 0;
    line-height: 1.3;
  }

  .vintage-racing-about .vra-video-subtitle {
    font-family: Georgia, 'Times New Roman', serif;
    font-style: italic;
    font-size: 13px;
    color: var(--vra-video-subtitle-color);
    margin: 6px 0 0;
    line-height: 1.6;
  }

  /* ── Placeholder ── */

  .vintage-racing-about .vra-video-placeholder {
    width: 100%;
    aspect-ratio: 16 / 9;
    background: rgba(255, 255, 255, 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.4);
    font-size: 14px;
  }

  /* ── Mobile ── */

  @media (max-width: 768px) {
    .vintage-racing-about {
      padding: 48px 0;
    }
  }
</style>

<section class="vintage-racing-about" id="vintage-racing-about-{{ section.id }}">
  {%- if section.settings.background_image != blank -%}
    <div class="vra-bg-image">
      {{ section.settings.background_image | image_url: width: 2000 | image_tag: loading: 'lazy' }}
    </div>
  {%- endif -%}
  <div class="vra-bg-overlay"></div>

  {%- if section.settings.show_stripes -%}
    <div class="stripe-container">
      <div class="stripe stripe--1"></div>
      <div class="stripe stripe--2"></div>
      <div class="stripe stripe--3"></div>
    </div>
  {%- endif -%}

  <div class="vra-inner">
    <div class="vra-header">
      {%- if section.settings.overline != blank -%}
        <p class="vra-overline">{{ section.settings.overline }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="vra-heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>

    <div class="vra-video-card" data-animate="media">
      <div class="vra-video-wrap">
        {%- if video != blank -%}
          <video
            id="vra-video-{{ section.id }}"
            {% if section.settings.autoplay %}autoplay{% endif %}
            muted
            loop
            playsinline
            controls
            {% if poster_url != '' %}poster="{{ poster_url }}"{% endif %}
          >
            {%- for source in video.sources -%}
              <source src="{{ source.url }}" type="{{ source.mime_type }}">
            {%- endfor -%}
          </video>
          <div class="vra-play-btn{% if section.settings.autoplay %} is-hidden{% endif %}" id="vra-play-{{ section.id }}"></div>
        {%- elsif thumbnail != blank -%}
          <img class="vra-thumb-img" src="{{ thumbnail | image_url: width: 1200 }}" alt="{{ section.settings.video_title | escape }}" loading="lazy">
        {%- else -%}
          <div class="vra-video-placeholder">Add a video or image in section settings</div>
        {%- endif -%}
      </div>
      <div class="vra-caption">
        <div class="vra-flag-icon"></div>
        <div class="vra-caption-text">
          {%- if section.settings.video_title != blank -%}
            <p class="vra-video-title">{{ section.settings.video_title }}</p>
          {%- endif -%}
          {%- if section.settings.video_subtitle != blank -%}
            <p class="vra-video-subtitle">{{ section.settings.video_subtitle }}</p>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    var sectionEl = document.getElementById('vintage-racing-about-{{ section.id }}');
    if (!sectionEl) return;

    var video = document.getElementById('vra-video-{{ section.id }}');
    var playBtn = document.getElementById('vra-play-{{ section.id }}');

    if (video && playBtn) {
      function syncPlayBtn() {
        if (video.paused) {
          playBtn.classList.remove('is-hidden');
        } else {
          playBtn.classList.add('is-hidden');
        }
      }

      video.addEventListener('play', syncPlayBtn);
      video.addEventListener('pause', syncPlayBtn);
      video.addEventListener('ended', syncPlayBtn);

      playBtn.addEventListener('click', function () {
        if (video.paused) {
          video.play();
        } else {
          video.pause();
        }
      });

      syncPlayBtn();
    }

    var mediaCard = sectionEl.querySelector('[data-animate="media"]');
    var hasAnimated = false;

    var observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting && !hasAnimated) {
          hasAnimated = true;
          if (mediaCard) mediaCard.classList.add('is-visible');
          observer.disconnect();
        }
      });
    }, { threshold: 0.15 });

    observer.observe(sectionEl);
  })();
</script>

{% schema %}
{
  "name": "Vintage Racing About",
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay Opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 30
    },
    {
      "type": "checkbox",
      "id": "show_stripes",
      "label": "Show decorative stripes",
      "default": true
    },
    {
      "type": "color",
      "id": "stripe_color_1",
      "label": "Stripe 1 Color",
      "default": "#F2A900"
    },
    {
      "type": "color",
      "id": "stripe_color_2",
      "label": "Stripe 2 Color",
      "default": "#D4541A"
    },
    {
      "type": "color",
      "id": "stripe_color_3",
      "label": "Stripe 3 Color",
      "default": "#B01A0E"
    },
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "text",
      "id": "overline",
      "label": "Overline Text",
      "default": "Slow Ride"
    },
    {
      "type": "color",
      "id": "overline_color",
      "label": "Overline Color",
      "default": "#D4541A"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Behind The Build"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Video"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Video"
    },
    {
      "type": "image_picker",
      "id": "video_thumbnail",
      "label": "Custom Thumbnail"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay video (muted)",
      "default": true
    },
    {
      "type": "color",
      "id": "play_button_color",
      "label": "Play Button Color",
      "default": "#B01A0E"
    },
    {
      "type": "header",
      "content": "Video Card"
    },
    {
      "type": "color",
      "id": "video_card_bg_color",
      "label": "Card Background Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "video_card_bg_opacity",
      "label": "Card Background Opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 45
    },
    {
      "type": "header",
      "content": "Caption"
    },
    {
      "type": "text",
      "id": "video_title",
      "label": "Caption Title",
      "default": "Collection Story"
    },
    {
      "type": "color",
      "id": "video_title_color",
      "label": "Caption Title Color",
      "default": "#1a1008"
    },
    {
      "type": "textarea",
      "id": "video_subtitle",
      "label": "Caption Text",
      "default": "Shot on location · Slow Ride Original"
    },
    {
      "type": "color",
      "id": "video_subtitle_color",
      "label": "Caption Text Color",
      "default": "#D4541A"
    }
  ],
  "presets": [
    {
      "name": "Vintage Racing About"
    }
  ]
}
{% endschema %}
