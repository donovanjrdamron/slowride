{% liquid
  assign image_position = section.settings.image_position | default: 'left'
  assign columns_desktop = section.settings.feature_columns_desktop | default: 2
%}

<section
  id="SlowRideGuarantee-{{ section.id }}"
  class="slow-ride-guarantee slow-ride-guarantee--{{ section.id }}{% if image_position == 'right' %} slow-ride-guarantee--image-right{% endif %}"
  style="
    --srg-max-width: {{ section.settings.section_max_width }}px;
    --srg-content-gap: {{ section.settings.content_gap }}px;
    --srg-padding-top: {{ section.settings.padding_top }}px;
    --srg-padding-bottom: {{ section.settings.padding_bottom }}px;
    --srg-feature-columns: {{ columns_desktop }};
    --srg-background: {{ section.settings.background_color }};
  "
>
  <div class="slow-ride-guarantee__inner">
    <div class="slow-ride-guarantee__media">
      {% if section.settings.image != blank %}
        {{
          section.settings.image
          | image_url: width: 2400
          | image_tag:
            class: 'slow-ride-guarantee__image',
            loading: 'lazy',
            widths: '750, 1000, 1400, 1800, 2200, 2400',
            sizes: '(min-width: 750px) 50vw, 100vw',
            alt: section.settings.image_alt | default: section.settings.image.alt | default: section.settings.heading
        }}
      {% else %}
        <div class="slow-ride-guarantee__image-placeholder" aria-hidden="true">
          {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
        </div>
      {% endif %}
    </div>

    <div class="slow-ride-guarantee__content">
      {% if section.settings.heading != blank %}
        <h2 class="slow-ride-guarantee__heading">{{ section.settings.heading | escape }}</h2>
      {% endif %}

      {% if section.settings.subheading != blank %}
        <div class="slow-ride-guarantee__subheading">{{ section.settings.subheading }}</div>
      {% endif %}

      <div class="slow-ride-guarantee__features" role="list">
        {% for block in section.blocks %}
          {% liquid
            assign has_icon = false
            assign has_title = false
            assign has_description = false
            assign show_item = false

            if block.settings.icon != blank
              assign has_icon = true
            endif

            if block.settings.title != blank
              assign has_title = true
            endif

            if block.settings.description != blank
              assign has_description = true
            endif

            if has_icon or has_title or has_description
              assign show_item = true
            endif
          %}

          {% if show_item %}
            <article class="slow-ride-guarantee__feature" role="listitem" {{ block.shopify_attributes }}>
              <div class="slow-ride-guarantee__feature-icon">
                {% if has_icon %}
                  {{
                    block.settings.icon
                    | image_url: width: 64
                    | image_tag:
                      class: 'slow-ride-guarantee__feature-icon-image',
                      loading: 'lazy',
                      widths: '32, 48, 64',
                      sizes: '24px',
                      alt: block.settings.icon.alt | default: block.settings.title
                  }}
                {% else %}
                  <span class="slow-ride-guarantee__feature-icon-dot" aria-hidden="true"></span>
                {% endif %}
              </div>

              <div class="slow-ride-guarantee__feature-text">
                {% if has_title %}
                  <h3 class="slow-ride-guarantee__feature-title">{{ block.settings.title | escape }}</h3>
                {% endif %}

                {% if has_description %}
                  <p class="slow-ride-guarantee__feature-description">{{ block.settings.description | escape }}</p>
                {% endif %}
              </div>
            </article>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .slow-ride-guarantee {
    background: var(--srg-background);
    padding-top: var(--srg-padding-top);
    padding-bottom: var(--srg-padding-bottom);
  }

  .slow-ride-guarantee__inner {
    max-width: var(--srg-max-width);
    margin: 0 auto;
    padding-inline: clamp(16px, 3vw, 32px);
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--srg-content-gap);
    align-items: stretch;
  }

  .slow-ride-guarantee__media {
    min-height: 260px;
  }

  .slow-ride-guarantee__image,
  .slow-ride-guarantee__image-placeholder,
  .slow-ride-guarantee__image-placeholder .placeholder-svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .slow-ride-guarantee__image {
    object-fit: cover;
    border-radius: 14px;
  }

  .slow-ride-guarantee__image-placeholder {
    border-radius: 14px;
    overflow: hidden;
    background: rgba(0, 0, 0, 0.06);
  }

  .slow-ride-guarantee__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 18px;
  }

  .slow-ride-guarantee__heading {
    margin: 0;
    font-size: clamp(2rem, 3vw, 3.3rem);
    line-height: 1.06;
    letter-spacing: -0.01em;
  }

  .slow-ride-guarantee__subheading {
    margin: 0;
  }

  .slow-ride-guarantee__subheading p {
    margin: 0;
  }

  .slow-ride-guarantee__features {
    display: grid;
    gap: 18px 22px;
    grid-template-columns: 1fr;
  }

  .slow-ride-guarantee__feature {
    display: grid;
    grid-template-columns: 24px minmax(0, 1fr);
    gap: 10px;
    align-items: start;
  }

  .slow-ride-guarantee__feature-icon {
    display: grid;
    place-items: center;
    min-height: 24px;
  }

  .slow-ride-guarantee__feature-icon-image {
    width: 24px;
    height: 24px;
    object-fit: contain;
    display: block;
  }

  .slow-ride-guarantee__feature-icon-dot {
    width: 10px;
    height: 10px;
    border-radius: 999px;
    background: currentColor;
    opacity: 0.75;
    display: block;
  }

  .slow-ride-guarantee__feature-title {
    margin: 0 0 3px;
    font-size: 1.25rem;
    line-height: 1.2;
  }

  .slow-ride-guarantee__feature-description {
    margin: 0;
    opacity: 0.85;
    font-size: 0.95rem;
    line-height: 1.45;
  }

  @media screen and (min-width: 750px) {
    .slow-ride-guarantee__inner {
      grid-template-columns: 1fr 1fr;
    }

    .slow-ride-guarantee--image-right .slow-ride-guarantee__media {
      order: 2;
    }

    .slow-ride-guarantee--image-right .slow-ride-guarantee__content {
      order: 1;
    }

    .slow-ride-guarantee__features {
      grid-template-columns: repeat(var(--srg-feature-columns), minmax(0, 1fr));
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Slow Ride Guarantee",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Perfect Fit, Guaranteed"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading",
      "default": "<p>Highlight the quality promises your customers can count on.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Main image"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Main image alt text"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position (desktop)",
      "default": "left",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ]
    },
    {
      "type": "range",
      "id": "feature_columns_desktop",
      "label": "Feature columns (desktop)",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "section_max_width",
      "label": "Section max width",
      "min": 900,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "default": 1300
    },
    {
      "type": "range",
      "id": "content_gap",
      "label": "Image/content gap",
      "min": 12,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 34
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#f7f7f7"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top spacing",
      "min": 0,
      "max": 140,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom spacing",
      "min": 0,
      "max": 140,
      "step": 4,
      "unit": "px",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "feature_item",
      "name": "Feature item",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Signature quality detail"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Describe this guarantee point for customers."
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Slow Ride Guarantee",
      "blocks": [
        {
          "type": "feature_item"
        },
        {
          "type": "feature_item"
        },
        {
          "type": "feature_item"
        },
        {
          "type": "feature_item"
        },
        {
          "type": "feature_item"
        },
        {
          "type": "feature_item"
        }
      ]
    }
  ]
}
{% endschema %}
