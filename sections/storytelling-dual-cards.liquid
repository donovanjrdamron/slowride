<div
  class="storytelling-dual-cards"
  style="
    --story-padding-top: {{ section.settings.padding_top }}px;
    --story-padding-bottom: {{ section.settings.padding_bottom }}px;
    --story-card-gap: {{ section.settings.card_gap }}px;
    --story-card-padding-mobile: {{ section.settings.card_padding_mobile }}px;
    --story-card-padding-desktop: {{ section.settings.card_padding_desktop }}px;
    --story-main-font-size-mobile: {{ section.settings.main_text_size_mobile }}px;
    --story-main-font-size-desktop: {{ section.settings.main_text_size_desktop }}px;
    --story-corner-font-size: {{ section.settings.corner_text_size }}px;
    --story-border-width: {{ section.settings.border_width }}px;
    --story-image-radius: {{ section.settings.image_corner_radius }}px;
    --story-frame-radius: {{ section.settings.frame_corner_radius }}px;
    --story-border-inset-mobile: {{ section.settings.border_inset_mobile }}px;
    --story-border-inset-desktop: {{ section.settings.border_inset_desktop }}px;
  "
>
  <article
    class="storytelling-dual-cards__card storytelling-dual-cards__card--1"
    style="
      --story-card-border-color: {{ section.settings.card_1_border_color }};
      --story-card-bg-color: {{ section.settings.card_1_background_color }};
      --story-main-text-color: {{ section.settings.card_1_main_text_color }};
      --story-corner-text-color: {{ section.settings.card_1_corner_text_color }};
      --story-card-bg-image: {% if section.settings.card_1_background_image != blank %}url('{{ section.settings.card_1_background_image | image_url: width: 2200 }}'){% else %}none{% endif %};
    "
  >
    {%- if section.settings.card_1_show_corner_text and section.settings.card_1_corner_text != blank -%}
      <p class="storytelling-dual-cards__corner storytelling-dual-cards__corner--{{ section.settings.card_1_corner_position }}">
        {{ section.settings.card_1_corner_text }}
      </p>
    {%- endif -%}

    <div class="storytelling-dual-cards__content">
      {%- if section.settings.card_1_main_text != blank -%}
        <div class="storytelling-dual-cards__main-text-wrap">
          <div class="storytelling-dual-cards__main-text rte">
            {{ section.settings.card_1_main_text }}
          </div>
        </div>
      {%- endif -%}

      {%- if section.settings.card_1_button_label != blank -%}
        <div class="storytelling-dual-cards__button-wrap">
          <a
            class="storytelling-dual-cards__button"
            {% if section.settings.card_1_button_link != blank %}
              href="{{ section.settings.card_1_button_link }}"
            {% else %}
              role="link"
              aria-disabled="true"
            {% endif %}
          >
            {{ section.settings.card_1_button_label }}
          </a>
        </div>
      {%- endif -%}
    </div>
  </article>

  <article
    class="storytelling-dual-cards__card storytelling-dual-cards__card--2"
    style="
      --story-card-border-color: {{ section.settings.card_2_border_color }};
      --story-card-bg-color: {{ section.settings.card_2_background_color }};
      --story-main-text-color: {{ section.settings.card_2_main_text_color }};
      --story-corner-text-color: {{ section.settings.card_2_corner_text_color }};
      --story-card-bg-image: {% if section.settings.card_2_background_image != blank %}url('{{ section.settings.card_2_background_image | image_url: width: 2200 }}'){% else %}none{% endif %};
    "
  >
    {%- if section.settings.card_2_show_corner_text and section.settings.card_2_corner_text != blank -%}
      <p class="storytelling-dual-cards__corner storytelling-dual-cards__corner--{{ section.settings.card_2_corner_position }}">
        {{ section.settings.card_2_corner_text }}
      </p>
    {%- endif -%}

    <div class="storytelling-dual-cards__content">
      {%- if section.settings.card_2_main_text != blank -%}
        <div class="storytelling-dual-cards__main-text-wrap">
          <div class="storytelling-dual-cards__main-text rte">
            {{ section.settings.card_2_main_text }}
          </div>
        </div>
      {%- endif -%}

      {%- if section.settings.card_2_button_label != blank -%}
        <div class="storytelling-dual-cards__button-wrap">
          <a
            class="storytelling-dual-cards__button"
            {% if section.settings.card_2_button_link != blank %}
              href="{{ section.settings.card_2_button_link }}"
            {% else %}
              role="link"
              aria-disabled="true"
            {% endif %}
          >
            {{ section.settings.card_2_button_label }}
          </a>
        </div>
      {%- endif -%}
    </div>
  </article>
</div>

{% stylesheet %}
  .storytelling-dual-cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--story-card-gap);
    width: 100%;
    padding-block: var(--story-padding-top) var(--story-padding-bottom);
  }

  .storytelling-dual-cards__card {
    position: relative;
    aspect-ratio: 1 / 1;
    min-height: 0;
    padding: 0;
    border-radius: var(--story-image-radius);
    background-color: var(--story-card-bg-color);
    background-image: var(--story-card-bg-image);
    background-size: cover;
    background-repeat: no-repeat;
    background-position: center;
    overflow: hidden;
    box-sizing: border-box;
  }

  .storytelling-dual-cards__card::after {
    content: '';
    position: absolute;
    inset: var(--story-border-inset-mobile);
    border: var(--story-border-width) solid var(--story-card-border-color);
    border-radius: var(--story-frame-radius);
    pointer-events: none;
  }

  .storytelling-dual-cards__content {
    position: absolute;
    inset: var(--story-card-padding-mobile);
    z-index: 2;
  }

  .storytelling-dual-cards__main-text-wrap {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    pointer-events: none;
    z-index: 1;
  }

  .storytelling-dual-cards__main-text {
    color: var(--story-main-text-color);
    font-size: var(--story-main-font-size-mobile);
    line-height: 0.95;
    max-width: 14ch;
    margin: 0;
  }

  .storytelling-dual-cards__main-text > * {
    margin: 0;
  }

  .storytelling-dual-cards__corner {
    position: absolute;
    top: max(16px, calc(var(--story-card-padding-mobile) * 0.7));
    color: var(--story-corner-text-color);
    font-size: var(--story-corner-font-size);
    line-height: 1.15;
    margin: 0;
    max-width: 42%;
    z-index: 3;
  }

  .storytelling-dual-cards__corner--top-left {
    left: max(16px, calc(var(--story-card-padding-mobile) * 0.7));
    text-align: left;
  }

  .storytelling-dual-cards__corner--top-right {
    right: max(16px, calc(var(--story-card-padding-mobile) * 0.7));
    text-align: right;
  }

  .storytelling-dual-cards__button-wrap {
    position: absolute;
    left: 50%;
    bottom: clamp(12px, 4vw, 40px);
    transform: translateX(-50%);
    z-index: 3;
  }

  .storytelling-dual-cards__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 10px 34px;
    border-radius: 999px;
    border: var(--story-border-width) solid var(--story-card-border-color);
    color: var(--story-card-border-color);
    background: transparent;
    text-decoration: none;
    font-size: clamp(16px, 2.2vw, 36px);
    line-height: 1;
  }

  .storytelling-dual-cards__button[aria-disabled='true'] {
    cursor: default;
  }

  @media screen and (min-width: 750px) {
    .storytelling-dual-cards {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .storytelling-dual-cards__card {
      padding: 0;
    }

    .storytelling-dual-cards__card::after {
      inset: var(--story-border-inset-desktop);
    }

    .storytelling-dual-cards__content {
      inset: var(--story-card-padding-desktop);
    }

    .storytelling-dual-cards__main-text {
      font-size: var(--story-main-font-size-desktop);
      max-width: 13ch;
    }

    .storytelling-dual-cards__corner {
      top: max(20px, calc(var(--story-card-padding-desktop) * 0.55));
    }

    .storytelling-dual-cards__corner--top-left {
      left: max(20px, calc(var(--story-card-padding-desktop) * 0.55));
    }

    .storytelling-dual-cards__corner--top-right {
      right: max(20px, calc(var(--story-card-padding-desktop) * 0.55));
    }
  }
{% endstylesheet %}

