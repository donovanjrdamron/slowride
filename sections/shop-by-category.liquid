{% liquid
  case section.settings.image_ratio
    when '1 / 1'
      assign image_ratio = '1 / 1'
    when '2 / 3'
      assign image_ratio = '2 / 3'
    else
      assign image_ratio = '3 / 4'
  endcase

  case section.settings.glass_tint
    when 'dark'
      assign glass_background = 'rgba(0, 0, 0, 0.28)'
      assign glass_border = 'rgba(255, 255, 255, 0.14)'
    else
      assign glass_background = 'rgba(255, 255, 255, 0.15)'
      assign glass_border = 'rgba(255, 255, 255, 0.28)'
  endcase
%}

<div
  class="section section--{{ section.settings.section_width }} shop-by-category spacing-style"
  data-reveal
  style="
    {% render 'spacing-style', settings: section.settings %}
    --shop-by-category-image-ratio: {{ image_ratio }};
    --shop-by-category-glass-background: {{ glass_background }};
    --shop-by-category-glass-border: {{ glass_border }};
    --shop-by-category-heading-size-desktop: {{ section.settings.heading_size }}px;
    --shop-by-category-heading-size-mobile: {{ section.settings.heading_size_mobile }}px;
    --shop-by-category-glass-height: {{ section.settings.glass_height }}px;
    --shop-by-category-eyebrow-size-desktop: {{ section.settings.eyebrow_size_desktop }}px;
    --shop-by-category-eyebrow-size-mobile: {{ section.settings.eyebrow_size_mobile }}px;
    --shop-by-category-title-size-desktop: {{ section.settings.title_size_desktop }}px;
    --shop-by-category-title-size-mobile: {{ section.settings.title_size_mobile }}px;
    --shop-by-category-subtitle-size-desktop: {{ section.settings.subtitle_size_desktop }}px;
    --shop-by-category-subtitle-size-mobile: {{ section.settings.subtitle_size_mobile }}px;
  "
>
  {% if section.settings.show_heading and section.settings.heading != blank %}
    <h2 class="shop-by-category__heading">{{ section.settings.heading }}</h2>
  {% endif %}

  <div class="shop-by-category__grid">
    {% for block in section.blocks %}
      {% liquid
        assign title = block.settings.title | strip
        assign subtitle = block.settings.subtitle | strip
        assign eyebrow = block.settings.eyebrow | strip
      %}

      {% if block.settings.link != blank %}
        <a
          class="shop-by-category__card"
          href="{{ block.settings.link }}"
          {{ block.shopify_attributes }}
          aria-label="{{ title | default: 'Shop category' | escape }}"
        >
      {% else %}
        <div class="shop-by-category__card" {{ block.shopify_attributes }}>
      {% endif %}
        <div class="shop-by-category__media">
          {% if block.settings.image != blank %}
            {{
              block.settings.image
              | image_url: width: 1200
              | image_tag:
                loading: 'lazy',
                class: 'shop-by-category__image',
                sizes: '(min-width: 750px) 25vw, 50vw',
                widths: '400, 600, 800, 1000, 1200',
                alt: title | default: block.settings.image.alt | escape
            }}
          {% else %}
            <div class="shop-by-category__placeholder">
              {{ 'collection-1' | placeholder_svg_tag: 'shop-by-category__placeholder-svg' }}
            </div>
          {% endif %}
        </div>

        <div class="shop-by-category__glass">
          {% if eyebrow != blank %}
            <p class="shop-by-category__eyebrow">{{ eyebrow }}</p>
          {% endif %}
          {% if title != blank %}
            <p class="shop-by-category__title">{{ title }}</p>
          {% endif %}
          {% if subtitle != blank %}
            <p class="shop-by-category__subtitle">{{ subtitle }}</p>
          {% endif %}
        </div>
      {% if block.settings.link != blank %}
        </a>
      {% else %}
        </div>
      {% endif %}
    {% endfor %}
  </div>
</div>

{% stylesheet %}
  .shop-by-category__heading {
    margin: 0 0 18px;
    font-size: var(--shop-by-category-heading-size-mobile, 30px);
    line-height: 1.1;

    @media screen and (width >= 750px) {
      font-size: var(--shop-by-category-heading-size-desktop, 40px);
    }
  }

  .shop-by-category__grid {
    display: grid;
    gap: 12px;
    grid-auto-flow: column;
    grid-auto-columns: minmax(100%, 100%);
    overflow-x: auto;
    overscroll-behavior-x: contain;
    scroll-snap-type: x mandatory;
    scroll-padding-inline: 0;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .shop-by-category__grid::-webkit-scrollbar {
    display: none;
  }

  .shop-by-category__card {
    scroll-snap-align: start;
    scroll-snap-stop: always;
  }

  .shop-by-category__media {
    transition: transform 0.35s ease, opacity 0.35s ease;
    transform: scale(0.985);
    opacity: 0.9;
  }

  .shop-by-category__card.is-swipe-active .shop-by-category__media {
    transform: scale(1);
    opacity: 1;
  }

  @media screen and (width >= 750px) {
    .shop-by-category__grid {
      gap: 16px;
      grid-auto-flow: row;
      grid-auto-columns: unset;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      overflow: visible;
      scroll-snap-type: none;
      scrollbar-width: auto;
    }

    .shop-by-category__media {
      transform: none;
      opacity: 1;
    }
  }

  .shop-by-category__card {
    position: relative;
    display: block;
    overflow: hidden;
    border-radius: 10px;
    text-decoration: none;
    color: inherit;
    aspect-ratio: var(--shop-by-category-image-ratio, 3 / 4);
  }

  .shop-by-category__media {
    position: absolute;
    inset: 0;
  }

  .shop-by-category__image,
  .shop-by-category__placeholder,
  .shop-by-category__placeholder-svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .shop-by-category__image {
    transition: transform 0.45s ease;
    transform-origin: center;
  }

  .shop-by-category__card:hover .shop-by-category__image,
  .shop-by-category__card:focus-visible .shop-by-category__image {
    transform: scale(1.05);
  }

  .shop-by-category__glass {
    position: absolute;
    inset-inline: 0;
    inset-block-end: 0;
    z-index: 1;
    min-height: var(--shop-by-category-glass-height, 120px);
    padding: 16px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    background: var(--shop-by-category-glass-background);
    border-top: 1px solid var(--shop-by-category-glass-border);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    mask-image: linear-gradient(to bottom, transparent 0%, black 25%);
    -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 25%);
  }

  .shop-by-category__eyebrow,
  .shop-by-category__title,
  .shop-by-category__subtitle {
    margin: 0;
    color: #fff;
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.4);
  }

  .shop-by-category__eyebrow {
    font-size: var(--shop-by-category-eyebrow-size-mobile, 11px);
    line-height: 1.2;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    opacity: 0.92;
    margin-bottom: 6px;
  }

  .shop-by-category__title {
    font-size: var(--shop-by-category-title-size-mobile, 18px);
    line-height: 1.15;
    font-weight: 700;
  }

  .shop-by-category__subtitle {
    margin-top: 6px;
    font-size: var(--shop-by-category-subtitle-size-mobile, 13px);
    line-height: 1.35;
    opacity: 0.96;
  }

    @media screen and (width >= 750px) {
    .shop-by-category__eyebrow {
      font-size: var(--shop-by-category-eyebrow-size-desktop, 11px);
    }

    .shop-by-category__title {
      font-size: var(--shop-by-category-title-size-desktop, 20px);
    }

    .shop-by-category__subtitle {
      font-size: var(--shop-by-category-subtitle-size-desktop, 13px);
    }
  }

  .shop-by-category--reveal-ready .shop-by-category__card {
    opacity: 0;
    transform: translateY(18px);
  }

  .shop-by-category--reveal-ready .shop-by-category__card.is-visible {
    animation: shop-by-category-fade-in 700ms cubic-bezier(0.22, 1, 0.36, 1) both;
    animation-delay: var(--shop-by-category-reveal-delay, 0ms);
  }

  @keyframes shop-by-category-fade-in {
    from {
      opacity: 0;
      transform: translateY(18px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
{% endstylesheet %}

{% javascript %}
  (() => {
    const sections = document.querySelectorAll('.shop-by-category[data-reveal]');
    if (!sections.length) return;

    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    sections.forEach((section) => {
      const cards = Array.from(section.querySelectorAll('.shop-by-category__card'));
      if (!cards.length) return;

      if (reduceMotion || !('IntersectionObserver' in window)) {
        cards.forEach((card) => card.classList.add('is-visible'));
      } else {
        section.classList.add('shop-by-category--reveal-ready');

        const observer = new IntersectionObserver(
          (entries, currentObserver) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;

              const card = entry.target;
              const delay = Number(card.dataset.revealIndex || 0) * 90;
              card.style.setProperty('--shop-by-category-reveal-delay', `${delay}ms`);
              card.classList.add('is-visible');
              currentObserver.unobserve(card);
            });
          },
          {
            threshold: 0.2,
            rootMargin: '0px 0px -10% 0px'
          }
        );

        cards.forEach((card, index) => {
          card.dataset.revealIndex = String(index);
          observer.observe(card);
        });
      }

      const grid = section.querySelector('.shop-by-category__grid');
      if (!grid) return;

      const mobileMedia = window.matchMedia('(max-width: 749px)');
      let animationFrameId = null;

      const updateActiveCard = () => {
        if (!mobileMedia.matches) {
          cards.forEach((card) => card.classList.remove('is-swipe-active'));
          return;
        }

        const gridRect = grid.getBoundingClientRect();
        const gridCenter = gridRect.left + gridRect.width / 2;
        let activeCard = cards[0];
        let shortestDistance = Number.POSITIVE_INFINITY;

        cards.forEach((card) => {
          const cardRect = card.getBoundingClientRect();
          const cardCenter = cardRect.left + cardRect.width / 2;
          const distance = Math.abs(cardCenter - gridCenter);

          if (distance < shortestDistance) {
            shortestDistance = distance;
            activeCard = card;
          }
        });

        cards.forEach((card) => card.classList.toggle('is-swipe-active', card === activeCard));
      };

      const requestActiveCardUpdate = () => {
        if (animationFrameId) return;
        animationFrameId = window.requestAnimationFrame(() => {
          animationFrameId = null;
          updateActiveCard();
        });
      };

      grid.addEventListener('scroll', requestActiveCardUpdate, { passive: true });
      window.addEventListener('resize', requestActiveCardUpdate);
      updateActiveCard();
    });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "Shop by Category",
  "tag": "section",
  "class": "section-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "max_blocks": 12,
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "checkbox",
      "id": "show_heading",
      "label": "Show section heading",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Shop by Category"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size (desktop)",
      "min": 20,
      "max": 84,
      "step": 2,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "label": "Heading size (mobile)",
      "min": 16,
      "max": 64,
      "step": 2,
      "unit": "px",
      "default": 30
    },
    {
      "type": "header",
      "content": "Cards"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image aspect ratio",
      "options": [
        {
          "value": "1 / 1",
          "label": "Square (1:1)"
        },
        {
          "value": "3 / 4",
          "label": "Portrait (3:4)"
        },
        {
          "value": "2 / 3",
          "label": "Tall (2:3)"
        }
      ],
      "default": "3 / 4"
    },
    {
      "type": "select",
      "id": "glass_tint",
      "label": "Glass tint",
      "options": [
        {
          "value": "light",
          "label": "Light (white frosted)"
        },
        {
          "value": "dark",
          "label": "Dark (black frosted)"
        }
      ],
      "default": "light"
    },
    {
      "type": "range",
      "id": "glass_height",
      "label": "Glass overlay height",
      "min": 56,
      "max": 240,
      "step": 4,
      "unit": "px",
      "default": 120
    },
    {
      "type": "header",
      "content": "Card text size"
    },
    {
      "type": "range",
      "id": "eyebrow_size_desktop",
      "label": "Eyebrow size (desktop)",
      "min": 8,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 11
    },
    {
      "type": "range",
      "id": "eyebrow_size_mobile",
      "label": "Eyebrow size (mobile)",
      "min": 8,
      "max": 28,
      "step": 1,
      "unit": "px",
      "default": 11
    },
    {
      "type": "range",
      "id": "title_size_desktop",
      "label": "Title size (desktop)",
      "min": 12,
      "max": 56,
      "step": 1,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "title_size_mobile",
      "label": "Title size (mobile)",
      "min": 12,
      "max": 48,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "subtitle_size_desktop",
      "label": "Subtitle size (desktop)",
      "min": 10,
      "max": 36,
      "step": 1,
      "unit": "px",
      "default": 13
    },
    {
      "type": "range",
      "id": "subtitle_size_mobile",
      "label": "Subtitle size (mobile)",
      "min": 10,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 13
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        {
          "value": "page-width",
          "label": "Page width"
        },
        {
          "value": "full-width",
          "label": "Full width"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
