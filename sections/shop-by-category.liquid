{% liquid
  case section.settings.image_ratio
    when '1 / 1'
      assign image_ratio = '1 / 1'
    when '2 / 3'
      assign image_ratio = '2 / 3'
    else
      assign image_ratio = '3 / 4'
  endcase

  case section.settings.glass_tint
    when 'dark'
      assign glass_background = 'rgba(0, 0, 0, 0.28)'
      assign glass_border = 'rgba(255, 255, 255, 0.14)'
    else
      assign glass_background = 'rgba(255, 255, 255, 0.15)'
      assign glass_border = 'rgba(255, 255, 255, 0.28)'
  endcase
%}

<div
  class="section section--{{ section.settings.section_width }} shop-by-category spacing-style"
  style="
    {% render 'spacing-style', settings: section.settings %}
    --shop-by-category-image-ratio: {{ image_ratio }};
    --shop-by-category-glass-background: {{ glass_background }};
    --shop-by-category-glass-border: {{ glass_border }};
  "
>
  {% if section.settings.show_heading and section.settings.heading != blank %}
    <h2 class="shop-by-category__heading">{{ section.settings.heading }}</h2>
  {% endif %}

  <div class="shop-by-category__grid">
    {% for block in section.blocks %}
      {% liquid
        assign title = block.settings.title | strip
        assign subtitle = block.settings.subtitle | strip
        assign eyebrow = block.settings.eyebrow | strip
      %}

      {% if block.settings.link != blank %}
        <a
          class="shop-by-category__card"
          href="{{ block.settings.link }}"
          {{ block.shopify_attributes }}
          aria-label="{{ title | default: 'Shop category' | escape }}"
        >
      {% else %}
        <div class="shop-by-category__card" {{ block.shopify_attributes }}>
      {% endif %}
        <div class="shop-by-category__media">
          {% if block.settings.image != blank %}
            {{
              block.settings.image
              | image_url: width: 1200
              | image_tag:
                loading: 'lazy',
                class: 'shop-by-category__image',
                sizes: '(min-width: 750px) 25vw, 50vw',
                widths: '400, 600, 800, 1000, 1200',
                alt: title | default: block.settings.image.alt | escape
            }}
          {% else %}
            <div class="shop-by-category__placeholder">
              {{ 'collection-1' | placeholder_svg_tag: 'shop-by-category__placeholder-svg' }}
            </div>
          {% endif %}
        </div>

        <div class="shop-by-category__glass">
          {% if eyebrow != blank %}
            <p class="shop-by-category__eyebrow">{{ eyebrow }}</p>
          {% endif %}
          {% if title != blank %}
            <p class="shop-by-category__title">{{ title }}</p>
          {% endif %}
          {% if subtitle != blank %}
            <p class="shop-by-category__subtitle">{{ subtitle }}</p>
          {% endif %}
        </div>
      {% if block.settings.link != blank %}
        </a>
      {% else %}
        </div>
      {% endif %}
    {% endfor %}
  </div>
</div>

{% stylesheet %}
  .shop-by-category__heading {
    margin: 0 0 18px;
  }

  .shop-by-category__grid {
    display: grid;
    gap: 16px;
    grid-template-columns: repeat(2, minmax(0, 1fr));

    @media screen and (width >= 750px) {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  .shop-by-category__card {
    position: relative;
    display: block;
    overflow: hidden;
    border-radius: 10px;
    text-decoration: none;
    color: inherit;
    aspect-ratio: var(--shop-by-category-image-ratio, 3 / 4);
  }

  .shop-by-category__media {
    position: absolute;
    inset: 0;
  }

  .shop-by-category__image,
  .shop-by-category__placeholder,
  .shop-by-category__placeholder-svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .shop-by-category__image {
    transition: transform 0.45s ease;
    transform-origin: center;
  }

  .shop-by-category__card:hover .shop-by-category__image,
  .shop-by-category__card:focus-visible .shop-by-category__image {
    transform: scale(1.05);
  }

  .shop-by-category__glass {
    position: absolute;
    inset-inline: 0;
    inset-block-end: 0;
    z-index: 1;
    padding: 16px;
    background: var(--shop-by-category-glass-background);
    border-top: 1px solid var(--shop-by-category-glass-border);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    mask-image: linear-gradient(to bottom, transparent 0%, black 25%);
    -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 25%);
  }

  .shop-by-category__eyebrow,
  .shop-by-category__title,
  .shop-by-category__subtitle {
    margin: 0;
    color: #fff;
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.4);
  }

  .shop-by-category__eyebrow {
    font-size: 0.6875rem;
    line-height: 1.2;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    opacity: 0.92;
    margin-bottom: 6px;
  }

  .shop-by-category__title {
    font-size: clamp(1rem, 1.5vw, 1.25rem);
    line-height: 1.15;
    font-weight: 700;
  }

  .shop-by-category__subtitle {
    margin-top: 6px;
    font-size: 0.8125rem;
    line-height: 1.35;
    opacity: 0.96;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Shop by Category",
  "tag": "section",
  "class": "section-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "max_blocks": 12,
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "checkbox",
      "id": "show_heading",
      "label": "Show section heading",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Shop by Category"
    },
    {
      "type": "header",
      "content": "Cards"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image aspect ratio",
      "options": [
        {
          "value": "1 / 1",
          "label": "Square (1:1)"
        },
        {
          "value": "3 / 4",
          "label": "Portrait (3:4)"
        },
        {
          "value": "2 / 3",
          "label": "Tall (2:3)"
        }
      ],
      "default": "3 / 4"
    },
    {
      "type": "select",
      "id": "glass_tint",
      "label": "Glass tint",
      "options": [
        {
          "value": "light",
          "label": "Light (white frosted)"
        },
        {
          "value": "dark",
          "label": "Dark (black frosted)"
        }
      ],
      "default": "light"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        {
          "value": "page-width",
          "label": "Page width"
        },
        {
          "value": "full-width",
          "label": "Full width"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "category_card",
      "name": "Category card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow text",
          "default": "Category"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Category name"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "Short supporting description"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop by Category",
      "category": "Image",
      "blocks": [
        {
          "type": "category_card",
          "settings": {
            "eyebrow": "Lifestyle",
            "title": "Racing Tees",
            "subtitle": "Everyday staples with vintage speed energy"
          }
        },
        {
          "type": "category_card",
          "settings": {
            "eyebrow": "Collection",
            "title": "Outerwear",
            "subtitle": "Layers for cool mornings and late rides"
          }
        },
        {
          "type": "category_card",
          "settings": {
            "eyebrow": "Featured",
            "title": "Accessories",
            "subtitle": "Caps, bags, and finishing details"
          }
        },
        {
          "type": "category_card",
          "settings": {
            "eyebrow": "New",
            "title": "Latest Drops",
            "subtitle": "Fresh arrivals in limited runs"
          }
        }
      ]
    }
  ]
}
{% endschema %}
