{%- liquid
  assign product_resource = closest.product
  if product_resource == blank
    assign product_resource = product
  endif
  if request.visual_preview_mode and product_resource == blank
    assign product_resource = collections.all.products.first
  endif

  assign variant = product_resource.selected_or_first_available_variant
-%}

{% if variant and variant.available %}
  <div
    class="sr-stock-badge spacing-style{% unless block.settings.enable_pulse %} sr-stock-badge--no-pulse{% endunless %}"
    style="{% render 'spacing-style', settings: block.settings %}"
    {{ block.shopify_attributes }}
  >
    <span class="sr-stock-dot"></span>
    <span class="sr-stock-text">{{ block.settings.text }}</span>
  </div>
{% endif %}

{% stylesheet %}
  .sr-stock-badge {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 14px;
  }

  .sr-stock-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: #22c55e;
    flex-shrink: 0;
    box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.6);
    animation: sr-pulse 2s infinite;
  }

  .sr-stock-badge--no-pulse .sr-stock-dot {
    animation: none;
    box-shadow: none;
  }

  @keyframes sr-pulse {
    0% {
      box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.6);
    }
    70% {
      box-shadow: 0 0 0 8px rgba(34, 197, 94, 0);
    }
    100% {
      box-shadow: 0 0 0 0 rgba(34, 197, 94, 0);
    }
  }

  .sr-stock-text {
    font-size: 13px;
    font-weight: 500;
    color: #1a1a1a;
    letter-spacing: 0.02em;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Stock badge",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "In Stock - Processes immediately"
    },
    {
      "type": "checkbox",
      "id": "enable_pulse",
      "label": "Enable pulse animation",
      "default": true
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "t:settings.left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "t:settings.right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Stock badge",
      "category": "Product",
      "settings": {
        "text": "In Stock - Processes immediately"
      }
    }
  ]
}
{% endschema %}
