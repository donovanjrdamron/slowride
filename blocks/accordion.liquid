<div class="sr-accordion-wrapper">
  <button class="sr-accordion-trigger" aria-expanded="false" {{ block.shopify_attributes }}>
    <span>{{ block.settings.title }}</span>
    <svg class="sr-accordion-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
      <polyline points="6 9 12 15 18 9" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>

  <div class="sr-accordion-body" hidden>
    <div
      class="sr-accordion-inner"
      {% if block.settings.bg_image != blank %}
        style="background-image: url('{{ block.settings.bg_image | image_url: width: 1200 }}');"
      {% endif %}
    >
      <div class="sr-accordion-glass">
        <div class="sr-accordion-content">
          {{ block.settings.content }}
        </div>
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
  .sr-accordion-wrapper {
    border-top: 1px solid #e5e5e5;
    border-bottom: 1px solid #e5e5e5;
    margin: -1px 0;
  }

  .sr-accordion-trigger {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 0;
    background: none;
    border: none;
    cursor: pointer;
    font-size: 15px;
    font-weight: 600;
    color: #1a1a1a;
    text-align: left;
    letter-spacing: 0.03em;
  }

  .sr-accordion-icon {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    transition: transform 0.3s ease;
  }

  .sr-accordion-trigger[aria-expanded='true'] .sr-accordion-icon {
    transform: rotate(180deg);
  }

  .sr-accordion-body {
    overflow: hidden;
  }

  .sr-accordion-inner {
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    border-radius: 8px;
    overflow: hidden;
    margin-bottom: 16px;
  }

  .sr-accordion-glass {
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    background-color: rgba(255, 255, 255, 0.6);
    padding: 24px;
  }

  .sr-accordion-content {
    font-size: 14px;
    color: #1a1a1a;
    line-height: 1.6;
  }
{% endstylesheet %}

<script>
  document.querySelectorAll('.sr-accordion-trigger').forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const body = trigger.nextElementSibling;
      const expanded = trigger.getAttribute('aria-expanded') === 'true';
      trigger.setAttribute('aria-expanded', !expanded);

      if (body) {
        body.hidden = expanded;
      }
    });
  });
</script>

{% schema %}
{
  "name": "Accordion",
  "tag": null,
  "class": "accordion",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Fit & Sizing"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Content",
      "default": "<p>True to size. We recommend sizing up if you're between sizes.</p>"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    }
  ],
  "presets": [
    {
      "name": "Accordion"
    }
  ]
}
{% endschema %}
