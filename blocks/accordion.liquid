{% liquid
  assign has_items = false
  for i in (1..5)
    assign title_key = 'item_' | append: i | append: '_title'
    assign content_key = 'item_' | append: i | append: '_content'
    assign item_title = block.settings[title_key]
    assign item_content = block.settings[content_key]
    unless item_title == blank or item_content == blank
      assign has_items = true
      break
    endunless
  endfor
%}

{% if has_items %}
  <div
    class="sr-accordion-wrapper"
    style="
      --sr-accordion-trigger-font-size: {{ block.settings.trigger_font_size }}px;
      --sr-accordion-trigger-font-weight: {{ block.settings.trigger_font_weight }};
      --sr-accordion-trigger-color: {{ block.settings.trigger_text_color }};
      --sr-accordion-content-font-size: {{ block.settings.content_font_size }}px;
      --sr-accordion-content-line-height: {{ block.settings.content_line_height }};
      --sr-accordion-content-color: {{ block.settings.content_text_color }};
      --sr-accordion-border-color: {{ block.settings.divider_color }};
      --sr-accordion-panel-radius: {{ block.settings.panel_radius }}px;
      --sr-accordion-panel-spacing: {{ block.settings.panel_spacing }}px;
      --sr-accordion-glass-padding: {{ block.settings.glass_padding }}px;
      --sr-accordion-glass-blur: {{ block.settings.glass_blur }}px;
      --sr-accordion-glass-saturation: {{ block.settings.glass_saturation }}%;
      --sr-accordion-glass-brightness: {{ block.settings.glass_brightness }}%;
      --sr-accordion-glass-border-width: {{ block.settings.glass_border_width }}px;
      --sr-accordion-glass-border-opacity: {{ block.settings.glass_border_opacity | divided_by: 100.0 }};
    "
    {{ block.shopify_attributes }}
  >
    {% for i in (1..5) %}
    {% liquid
      assign title_key = 'item_' | append: i | append: '_title'
      assign content_key = 'item_' | append: i | append: '_content'
      assign item_title = block.settings[title_key]
      assign item_content = block.settings[content_key]
    %}
    {% unless item_title == blank or item_content == blank %}
      {% assign accordion_id = block.id | append: '-' | append: i %}
      <button
        class="sr-accordion-trigger"
        type="button"
        aria-expanded="false"
        aria-controls="sr-accordion-body-{{ accordion_id }}"
        id="sr-accordion-trigger-{{ accordion_id }}"
      >
        <span>{{ item_title }}</span>
        <svg class="sr-accordion-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
          <polyline points="6 9 12 15 18 9" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <div
        class="sr-accordion-body"
        id="sr-accordion-body-{{ accordion_id }}"
        role="region"
        aria-labelledby="sr-accordion-trigger-{{ accordion_id }}"
        hidden
      >
        <div
          class="sr-accordion-inner"
          {% if block.settings.bg_image != blank %}
            style="background-image: url('{{ block.settings.bg_image | image_url: width: 1200 }}');"
          {% endif %}
        >
          <div
            class="sr-accordion-glass"
            style="
              background-color: {{ block.settings.glass_overlay_color | color_modify: 'alpha', block.settings.glass_overlay_opacity | divided_by: 100.0 }};
              border-color: {{ block.settings.glass_border_color | color_modify: 'alpha', block.settings.glass_border_opacity | divided_by: 100.0 }};
            "
          >
            <div class="sr-accordion-content">
              {{ item_content }}
            </div>
          </div>
        </div>
      </div>
    {% endunless %}
    {% endfor %}
  </div>
{% endif %}

{% stylesheet %}
  .sr-accordion-wrapper {
    border-top: 1px solid var(--sr-accordion-border-color, #e5e5e5);
    border-bottom: 1px solid var(--sr-accordion-border-color, #e5e5e5);
    margin: -1px 0;
  }

  .sr-accordion-trigger {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 0;
    background: none;
    border: none;
    border-top: 1px solid var(--sr-accordion-border-color, #e5e5e5);
    cursor: pointer;
    font-size: var(--sr-accordion-trigger-font-size, 15px);
    font-weight: var(--sr-accordion-trigger-font-weight, 600);
    color: var(--sr-accordion-trigger-color, #1a1a1a);
    text-align: left;
    letter-spacing: 0.03em;
  }

  .sr-accordion-icon {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    transition: transform 0.3s ease;
  }

  .sr-accordion-trigger[aria-expanded='true'] .sr-accordion-icon {
    transform: rotate(180deg);
  }

  .sr-accordion-body {
    overflow: hidden;
  }

  .sr-accordion-inner {
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    border-radius: var(--sr-accordion-panel-radius, 8px);
    overflow: hidden;
    margin-bottom: var(--sr-accordion-panel-spacing, 16px);
  }

  .sr-accordion-glass {
    backdrop-filter: blur(var(--sr-accordion-glass-blur, 12px)) saturate(var(--sr-accordion-glass-saturation, 100%))
      brightness(var(--sr-accordion-glass-brightness, 100%));
    -webkit-backdrop-filter: blur(var(--sr-accordion-glass-blur, 12px)) saturate(var(--sr-accordion-glass-saturation, 100%))
      brightness(var(--sr-accordion-glass-brightness, 100%));
    border: var(--sr-accordion-glass-border-width, 1px) solid transparent;
    padding: var(--sr-accordion-glass-padding, 24px);
  }

  .sr-accordion-content {
    font-size: var(--sr-accordion-content-font-size, 14px);
    color: var(--sr-accordion-content-color, #1a1a1a);
    line-height: var(--sr-accordion-content-line-height, 1.6);
  }
{% endstylesheet %}

<script>
  document.querySelectorAll('.sr-accordion-wrapper').forEach((wrapper) => {
    if (wrapper.dataset.srAccordionBound === 'true') return;
    wrapper.dataset.srAccordionBound = 'true';

    wrapper.querySelectorAll('.sr-accordion-trigger').forEach((trigger) => {
      trigger.addEventListener('click', () => {
        const body = trigger.nextElementSibling;
        const expanded = trigger.getAttribute('aria-expanded') === 'true';
        trigger.setAttribute('aria-expanded', (!expanded).toString());

        if (body) {
          body.hidden = expanded;
        }
      });
    });
  });
</script>

