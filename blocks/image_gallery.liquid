{% case block.type %}
  {% when 'image_gallery' %}
    <div class="sr-gallery-wrapper" {{ block.shopify_attributes }}>
      <div
        class="sr-gallery-header"
        style="text-align: {{ block.settings.heading_align }}; margin-bottom: {{ block.settings.heading_gap }}px;"
      >
        <h2
          class="sr-gallery-heading"
          style="font-size: {{ block.settings.heading_size }}px; color: {{ block.settings.heading_color }};"
        >
          {{ block.settings.heading }}
        </h2>
      </div>

      <div class="sr-gallery-track" id="sr-track-{{ block.id }}">
        {% for i in (1..15) %}
          {% assign image_key = 'image_' | append: i %}
          {% assign image = block.settings[image_key] %}
          {% if image != blank %}
            <div class="sr-gallery-card">
              <img src="{{ image | image_url: width: 600 }}" alt="Gallery image {{ i }}" loading="lazy">
            </div>
          {% endif %}
        {% endfor %}
      </div>

      <div class="sr-gallery-dots" id="sr-dots-{{ block.id }}"></div>
    </div>
{% endcase %}

{% schema %}
{
  "name": "Image Gallery",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading Text",
      "default": "Enjoy Getting There."
    },
    {
      "type": "select",
      "id": "heading_align",
      "label": "Heading Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#1c1a17"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading Size",
      "min": 20,
      "max": 80,
      "step": 2,
      "default": 48
    },
    {
      "type": "range",
      "id": "heading_gap",
      "label": "Space Below Heading",
      "min": 8,
      "max": 60,
      "step": 4,
      "default": 24
    },
    {
      "type": "header",
      "content": "Images"
    },
    { "type": "image_picker", "id": "image_1", "label": "Image 1" },
    { "type": "image_picker", "id": "image_2", "label": "Image 2" },
    { "type": "image_picker", "id": "image_3", "label": "Image 3" },
    { "type": "image_picker", "id": "image_4", "label": "Image 4" },
    { "type": "image_picker", "id": "image_5", "label": "Image 5" },
    { "type": "image_picker", "id": "image_6", "label": "Image 6" },
    { "type": "image_picker", "id": "image_7", "label": "Image 7" },
    { "type": "image_picker", "id": "image_8", "label": "Image 8" },
    { "type": "image_picker", "id": "image_9", "label": "Image 9" },
    { "type": "image_picker", "id": "image_10", "label": "Image 10" },
    { "type": "image_picker", "id": "image_11", "label": "Image 11" },
    { "type": "image_picker", "id": "image_12", "label": "Image 12" },
    { "type": "image_picker", "id": "image_13", "label": "Image 13" },
    { "type": "image_picker", "id": "image_14", "label": "Image 14" },
    { "type": "image_picker", "id": "image_15", "label": "Image 15" }
  ],
  "presets": [
    {
      "name": "Image Gallery",
      "category": "Product"
    }
  ]
}
{% endschema %}
